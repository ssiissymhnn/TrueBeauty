{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TrueBeauty: 로컬 서버 (8765)",
      "type": "shell",
      "command": "python -m http.server 8765",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Serving HTTP"
        }
      }
    }
  ]
}
